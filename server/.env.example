# Copy to .env and fill in your Supabase credentials
# These stay SERVER-SIDE ONLY — never exposed to the browser

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server config
PORT=3001
# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# JWT — generate a strong secret: openssl rand -base64 64
JWT_SECRET=replace-with-a-strong-random-secret-minimum-32-chars
